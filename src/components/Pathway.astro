---
const steps = [
  { code: 'WM-010', label: 'Explorer', ages: '10–13', color: 'sky', tier: 'rover' },
  { code: 'WM-020', label: 'Navigator', ages: '13–16', color: 'teal', tier: 'rover' },
  { code: 'WM-030', label: 'Cadet', ages: '16–18', color: 'violet', tier: 'rover' },
  { code: 'WM-100', label: 'Foundation', ages: null, color: 'accent', tier: 'world' },
  { code: 'WM-200', label: 'Practitioner', ages: null, color: 'emerald', tier: 'world' },
  { code: 'WM-300', label: 'Specialist', ages: null, color: 'gold', tier: 'world' },
  { code: 'WM-400', label: 'Expert', ages: null, color: 'rose', tier: 'world' },
];
---

<section class="relative py-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <div class="text-sm font-semibold text-text-faint tracking-widest uppercase mb-4">Complete Learning Pathway</div>
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        From curious explorer to world model engineer
      </h2>
    </div>

    <!-- Desktop: horizontal pathway -->
    <div class="hidden lg:block">
      <div class="relative flex items-center justify-between">
        <!-- Connecting line -->
        <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-px bg-gradient-to-r from-sky-500/40 via-accent/40 to-rose/40"></div>

        <!-- Bridge marker -->
        <div class="absolute left-[40.5%] top-1/2 -translate-y-1/2 -translate-x-1/2 z-20">
          <div class="w-px h-16 bg-gradient-to-b from-transparent via-white/20 to-transparent absolute left-1/2 -translate-x-1/2 -top-8"></div>
        </div>

        {steps.map((step, i) => (
          <div class="relative z-10 flex flex-col items-center gap-3">
            {i === 3 && (
              <div class="absolute -left-10 top-1/2 -translate-y-1/2 flex flex-col items-center">
                <div class="w-6 h-6 rounded-full bg-surface border-2 border-white/20 flex items-center justify-center">
                  <svg class="w-3 h-3 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </div>
              </div>
            )}
            <div class={`w-14 h-14 rounded-xl bg-${step.tier === 'rover' ? step.color + '-500' : step.color}/15 border border-${step.tier === 'rover' ? step.color + '-500' : step.color}/30 flex items-center justify-center transition-all hover:scale-110 hover:bg-${step.tier === 'rover' ? step.color + '-500' : step.color}/25 cursor-default`}>
              <span class={`text-xs font-bold text-${step.tier === 'rover' ? step.color + '-400' : step.color + '-light'}`}>{step.code.split('-')[1]}</span>
            </div>
            <div class="text-center">
              <div class={`text-xs font-semibold text-${step.tier === 'rover' ? step.color + '-400' : step.color + '-light'}`}>{step.label}</div>
              {step.ages && <div class="text-[10px] text-text-faint mt-0.5">{step.ages}</div>}
            </div>
          </div>
        ))}
      </div>

      <!-- Tier labels -->
      <div class="flex justify-between mt-8">
        <div class="flex items-center gap-2 text-xs text-text-faint">
          <div class="w-3 h-px bg-sky-500/60"></div>
          <span>Rover Pathways</span>
          <span class="text-sky-400 font-mono">&middot;</span>
          <a href="https://rover.castalia.institute" class="text-sky-400 hover:text-sky-300 transition-colors">rover.castalia.institute</a>
        </div>
        <div class="flex items-center gap-2 text-xs text-text-faint">
          <span>Professional Tracks</span>
          <span class="text-accent-light font-mono">&middot;</span>
          <span class="text-accent-light">world.castalia.institute</span>
          <div class="w-3 h-px bg-accent/60"></div>
        </div>
      </div>
    </div>

    <!-- Mobile: vertical pathway -->
    <div class="lg:hidden">
      <div class="relative ml-6">
        <div class="absolute left-0 top-0 bottom-0 w-px bg-gradient-to-b from-sky-500/40 via-accent/40 to-rose/40"></div>
        <div class="space-y-6">
          {steps.map((step, i) => (
            <div class="relative pl-8">
              {i === 3 && (
                <div class="mb-4 -ml-8 pl-8 py-2 border-l-2 border-dashed border-white/15">
                  <span class="text-xs text-text-faint uppercase tracking-wider">Bridge to Professional Tracks</span>
                </div>
              )}
              <div class={`absolute left-0 top-1 -translate-x-1/2 w-3 h-3 rounded-full bg-${step.tier === 'rover' ? step.color + '-500' : step.color} border-2 border-midnight`}></div>
              <div class="flex items-baseline gap-3">
                <span class={`text-sm font-bold text-${step.tier === 'rover' ? step.color + '-400' : step.color + '-light'}`}>{step.code}</span>
                <span class="text-sm text-white font-medium">{step.label}</span>
                {step.ages && <span class="text-xs text-text-faint">{step.ages}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
