---
const pathways = [
  {
    level: 'Explorer',
    code: 'WM-010',
    ages: 'Ages 10–13',
    title: 'World Explorer',
    description: 'Observe, hypothesize, and experiment. Drive real RC vehicles on the terrAIn bed, measure forces with sensors, and discover how the physical world works through hands-on missions.',
    color: 'sky',
    modules: [
      'How Things Move: Forces & Motion',
      'Rover Sensors: Seeing the World Like a Robot',
      'terrAIn Lab: Drive & Observe on Real Soil',
      'Build Your First Simulation in Scratch',
    ],
    hours: 16,
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21a9 9 0 100-18 9 9 0 000 18z"/><path d="M3.6 9h16.8M3.6 15h16.8"/><path d="M12 3a15.3 15.3 0 014 9 15.3 15.3 0 01-4 9 15.3 15.3 0 01-4-9 15.3 15.3 0 014-9z"/></svg>`,
  },
  {
    level: 'Navigator',
    code: 'WM-020',
    ages: 'Ages 13–16',
    title: 'Reality Navigator',
    description: 'Go deeper into 3D environments, game engines, and basic programming. Program an ESP32 rover on the terrAIn bed and build a digital twin of the terrain.',
    color: 'teal',
    modules: [
      '3D Worlds: Intro to Game Engines & Physics',
      'Python for Young Engineers',
      'terrAIn Lab: Program the ESP32 Rover',
      'Digital Twins: Mirror the Real Terrain Bed',
    ],
    hours: 24,
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`,
  },
  {
    level: 'Cadet',
    code: 'WM-030',
    ages: 'Ages 16–18',
    title: 'Simulation Cadet',
    description: 'Bridge to the professional track. Intro to machine learning, neural networks, and building simple world models. Train a rover to navigate the terrAIn bed autonomously.',
    color: 'violet',
    modules: [
      'Neural Networks from Scratch',
      'Intro to Reinforcement Learning',
      'Building a Simple World Model',
      'terrAIn Capstone: Autonomous Excavation',
    ],
    hours: 32,
    icon: `<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>`,
  },
];
---

<section id="rover" class="relative py-32 bg-deep/50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl mb-6">
      <div class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase mb-4">
        <span class="text-sky-400">Rover Pathways</span>
        <span class="text-text-faint">&middot;</span>
        <span class="text-text-faint">Young Learners</span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        Start the journey early
      </h2>
      <p class="text-lg text-text-dim">
        The Rover Pathways are designed for younger learners who want to explore how the world works and build toward a career in world model engineering. Each pathway feeds directly into the professional certification tracks.
      </p>
    </div>

    <!-- Platform callouts -->
    <div class="flex flex-col sm:flex-row gap-3 mb-12">
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-surface/50 border border-white/5 w-fit">
        <svg class="w-5 h-5 text-sky-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.54a4.5 4.5 0 00-6.364-6.364L4.5 8.318"/>
        </svg>
        <span class="text-sm text-text-dim">
          Missions &amp; simulators at
          <a href="https://rover.castalia.institute" class="text-sky-400 hover:text-sky-300 font-medium underline underline-offset-2 transition-colors">rover.castalia.institute</a>
        </span>
      </div>
      <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-surface/50 border border-white/5 w-fit">
        <svg class="w-5 h-5 text-[#7c9c6b] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/>
        </svg>
        <span class="text-sm text-text-dim">
          Lab hardware powered by
          <a href="https://terrain.castalia.institute" class="text-[#7c9c6b] hover:text-[#9dbd87] font-medium underline underline-offset-2 transition-colors">terrAIn</a>
          <span class="text-text-faint">&middot; terrAIn Home kit</span>
        </span>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      {pathways.map((p) => (
        <div class="group relative rounded-2xl border border-white/5 bg-surface/40 backdrop-blur-sm p-8 hover:border-white/10 hover:bg-surface/60 transition-all duration-300 flex flex-col">
          <div class="flex items-center justify-between mb-5">
            <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-${p.color}-500/10 border border-${p.color}-500/20`}>
              <Fragment set:html={p.icon} />
              <span class={`text-sm font-semibold text-${p.color}-400`}>{p.level}</span>
            </div>
            <span class="text-xs font-mono text-text-faint">{p.code}</span>
          </div>

          <div class={`inline-block text-xs font-medium px-2 py-0.5 rounded-md bg-${p.color}-500/10 text-${p.color}-400 border border-${p.color}-500/15 w-fit mb-4`}>
            {p.ages}
          </div>

          <h3 class="text-xl font-bold text-white mb-3">{p.title}</h3>
          <p class="text-text-dim text-sm leading-relaxed mb-6">{p.description}</p>

          <div class="space-y-2 mb-6 flex-1">
            {p.modules.map((mod) => (
              <div class="flex items-start gap-3 text-sm">
                <div class={`w-1.5 h-1.5 rounded-full bg-${p.color}-400 mt-1.5 shrink-0`}></div>
                <span class="text-text-dim">{mod}</span>
              </div>
            ))}
          </div>

          <div class="flex items-center justify-between pt-4 border-t border-white/5">
            <span class="text-sm text-text-faint">{p.hours} hours</span>
            <span class={`text-sm font-medium text-${p.color}-400 group-hover:underline cursor-pointer`}>
              Learn more &rarr;
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
